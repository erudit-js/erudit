{
  "type": "module",
  "name": "@erudit-js/prose",
  "version": "4.3.4",
  "description": "📝 JSX prose subsystem for Erudit sites",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./app": {
      "import": "./dist/app/index.js",
      "types": "./dist/app/index.d.ts"
    },
    "./elements/*": {
      "import": "./dist/elements/*.js",
      "types": "./dist/elements/*.d.ts"
    },
    "./raw": "./raw.d.ts"
  },
  "files": [
    "dist",
    "raw.d.ts"
  ],
  "license": "MIT",
  "scripts": {
    "build": "bun run script/build.ts",
    "dev": "bun run script/dev.ts",
    "test": "bun vitest run",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@erudit-js/core": "workspace:*",
    "@floating-ui/vue": "catalog:",
    "image-size": "catalog:",
    "katex": "^0.16.44",
    "mermaid": "^11.13.0",
    "photoswipe": "^5.4.4",
    "tsprose": "catalog:",
    "vue": "catalog:"
  },
  "devDependencies": {
    "glob": "catalog:",
    "oxc-transform": "0.123.0",
    "ts-xor": "catalog:"
  }
}
